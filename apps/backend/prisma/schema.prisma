// ============================================================
// EduBridge Network — Prisma Schema
// PostgreSQL. Designed for 200,000+ users.
// All tables, PKs, FKs, indexes, composite indexes, enums.
// ============================================================

generator client {
  provider      = "prisma-client-js"
  // "native" covers local dev; the linux-musl-openssl-3.0.x target is required
  // for the node:20-alpine production image (Alpine ships OpenSSL 3).
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  STUDENT
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
  PENDING_VERIFICATION
}

enum AuthProvider {
  EMAIL
  GOOGLE
  PHONE
}

enum CollegeVerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum ReviewCategory {
  PLACEMENT
  HOSTEL
  FACULTY
  CAMPUS_LIFE
  ROI
  COMMUNITY_MANAGERS
}

enum ResourceType {
  NOTES
  PDF
  ROADMAP
  PLACEMENT_REPORT
  STUDY_MATERIAL
}

enum TransferStatus {
  EXPLORING
  ELIGIBLE
  APPLIED
  COMPLETED
}

enum NotificationType {
  LIKE
  COMMENT
  MENTION
  MESSAGE
  FOLLOW
  SCHOLARSHIP
  INTERNSHIP_DEADLINE
  TRANSFER_UPDATE
  BADGE_EARNED
  SYSTEM
  INTERNSHIP_PAYMENT_CONFIRMED
  INTERNSHIP_TASK_ASSIGNED
  INTERNSHIP_TASK_REVIEWED
  INTERNSHIP_APPLICATION_ALLOCATED
  INTERNSHIP_APPLICATION_REVIEWED
  INTERNSHIP_PAYOUT_SENT
  CERTIFICATE_ISSUED
}

enum ReputationAction {
  POST_CREATED
  COMMENT_CREATED
  HELPFUL_ANSWER
  REVIEW_CREATED
  RESOURCE_UPLOADED
  RECEIVED_LIKE
}

enum BadgeTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum ReportTargetType {
  POST
  COMMENT
  USER
  REVIEW
  RESOURCE
  MESSAGE
}

enum ReportStatus {
  OPEN
  REVIEWING
  RESOLVED
  DISMISSED
}

enum ChatType {
  DIRECT
  COMMUNITY
  GROUP
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

enum VerificationPurpose {
  EMAIL_VERIFY
  PASSWORD_RESET
  MAGIC_LINK
}

enum VerificationMethod {
  COLLEGE_EMAIL
  ID_CARD
  ADMISSION_PROOF
}

enum VerificationRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EnrollmentSubtype {
  GUIDED_LEARNING
  OWN_PROJECT
}

enum EnrollmentStatus {
  PENDING_PAYMENT
  ACTIVE
  COMPLETED
  CANCELLED
}

enum EnrollmentTaskStatus {
  ASSIGNED
  SUBMITTED
  APPROVED
  REJECTED
}

enum TrackBApplicationStatus {
  PENDING
  ALLOCATED
  SUBMITTED
  APPROVED
  REJECTED
}

enum TrackBAllocationType {
  PAID_CLIENT_WORK
  SKILL_BUILDING_TASK
}

enum CertificateSourceType {
  TRACK_A_ENROLLMENT
  TRACK_B_APPLICATION
}

// ============================================================
// IDENTITY & AUTH
// ============================================================

model User {
  id           String       @id @default(cuid())
  email        String?      @unique
  phone        String?      @unique
  passwordHash String?
  authProvider AuthProvider @default(EMAIL)
  role         UserRole     @default(STUDENT)
  status       UserStatus   @default(PENDING_VERIFICATION)

  emailVerifiedAt DateTime?
  phoneVerifiedAt DateTime?

  // Security / brute force protection
  failedLoginCount Int       @default(0)
  lockedUntil      DateTime?
  lastLoginAt      DateTime?

  // Reputation denormalized for fast leaderboard reads
  reputationPoints Int @default(0)

  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  profile            Profile?
  sessions           Session[]
  devices            Device[]
  emailVerifications EmailVerification[]
  otpVerifications   OtpVerification[]
  oauthAccounts      OAuthAccount[]

  resources         Resource[]
  resourceDownloads ResourceDownload[]
  resourceRatings   ResourceRating[]
  resourceBookmarks ResourceBookmark[]
  resourceLikes     ResourceLike[]
  resourceComments  ResourceComment[]

  transfers   Transfer[]
  reviews     Review[]
  reviewVotes ReviewVote[]

  reputationEvents       ReputationEvent[]
  userBadges             UserBadge[]
  notifications          Notification[]    @relation("NotificationRecipient")
  triggeredNotifications Notification[]    @relation("NotificationActor")

  chatParticipants ChatParticipant[]
  messages         Message[]
  complaints       Complaint[]

  reportsMade    Report[]   @relation("Reporter")
  reportsAgainst Report[]   @relation("ReportedUser")
  auditLogs      AuditLog[]

  verificationRequests VerificationRequest[]
  referralsPosted      Referral[]
  profileLead          ProfileLead?

  trackAEnrollments  TrackAEnrollment[]
  trackBApplications TrackBApplication[]
  certificates       Certificate[]

  @@index([status])
  @@index([role])
  @@index([reputationPoints(sort: Desc)])
  @@index([createdAt])
  @@map("users")
}

model Profile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName  String
  username  String? @unique
  avatarUrl String?
  bio       String?

  collegeId    String?
  college      College?    @relation(fields: [collegeId], references: [id])
  universityId String?
  university   University? @relation(fields: [universityId], references: [id])

  course String?
  branch String?
  year   Int?
  gender String? // Male | Female | Other | Prefer not to say
  cgpa   Float?
  state  String?
  city   String?

  collegeVerification CollegeVerificationStatus @default(UNVERIFIED)

  interests String[] // tags: Placement, DSA, AI, Startups...

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([collegeId])
  @@index([universityId])
  @@index([state, city])
  @@map("profiles")
}

model OAuthAccount {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider       AuthProvider
  providerUserId String
  accessToken    String?
  refreshToken   String?
  createdAt      DateTime     @default(now())

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("oauth_accounts")
}

model Session {
  id       String  @id @default(cuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId String?
  device   Device? @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  refreshTokenHash String
  userAgent        String?
  ipAddress        String?
  rememberMe       Boolean @default(false)

  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Device {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String?
  platform   String?
  pushToken  String?
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())

  sessions Session[]

  @@index([userId])
  @@map("devices")
}

model EmailVerification {
  id        String              @id @default(cuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  purpose   VerificationPurpose @default(EMAIL_VERIFY)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime            @default(now())

  @@index([userId])
  @@index([tokenHash])
  @@map("email_verifications")
}

model OtpVerification {
  id        String    @id @default(cuid())
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone     String
  codeHash  String
  attempts  Int       @default(0)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([phone])
  @@index([expiresAt])
  @@map("otp_verifications")
}

// ============================================================
// COLLEGE DATA LAYER (the moat)
// ============================================================

model University {
  id              String   @id @default(cuid())
  name            String   @unique
  shortName       String?
  state           String?
  city            String?
  type            String? // Private, Central, State, Deemed
  establishedYear Int?
  website         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  colleges College[]
  profiles Profile[]

  @@index([state])
  @@map("universities")
}

model College {
  id           String      @id @default(cuid())
  name         String
  slug         String      @unique
  universityId String?
  university   University? @relation(fields: [universityId], references: [id])

  state    String?
  city     String?
  type     String?
  logoUrl  String?
  coverUrl String?
  website  String?
  nirfRank Int?

  // Aggregated metrics (denormalized for fast reads)
  avgPlacementPackage Float?
  reviewCount         Int    @default(0)
  avgRating           Float  @default(0)

  // Ingestion provenance
  sourceSystem String? // JoSAA, CSAB, UPTAC, manual
  externalId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profiles             Profile[]
  reviews              Review[]
  cutoffs              CollegeCutoff[]
  transfersFrom        Transfer[]            @relation("TransferFromCollege")
  transfersTo          Transfer[]            @relation("TransferToCollege")
  transferRequirements TransferRequirement[]
  resources            Resource[]
  faqs                 CollegeFaq[]
  verificationRequests VerificationRequest[]

  @@index([state, city])
  @@index([nirfRank])
  @@index([avgRating(sort: Desc)])
  @@index([sourceSystem, externalId])
  @@map("colleges")
}

model CollegeCutoff {
  id           String  @id @default(cuid())
  collegeId    String
  college      College @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  year         Int
  round        Int?
  branch       String
  category     String // GEN, OBC, SC, ST, EWS
  quota        String? // AI, HS, OS
  openingRank  Int?
  closingRank  Int?
  sourceSystem String? // JoSAA, CSAB, UPTAC

  createdAt DateTime @default(now())

  @@index([collegeId, year])
  @@index([branch, category])
  @@map("college_cutoffs")
}

// ============================================================
// MODULE 2: TRANSFER HUB
// ============================================================

model Transfer {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  fromCollegeId String?
  fromCollege   College? @relation("TransferFromCollege", fields: [fromCollegeId], references: [id])
  toCollegeId   String?
  toCollege     College? @relation("TransferToCollege", fields: [toCollegeId], references: [id])

  currentYear   Int?
  cgpa          Float?
  branch        String?
  status        TransferStatus @default(EXPLORING)
  story         String? // transfer story (optional, shareable)
  isStoryPublic Boolean        @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([toCollegeId])
  @@index([status])
  @@map("transfers")
}

model TransferRequirement {
  id             String    @id @default(cuid())
  collegeId      String
  college        College   @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  branch         String?
  minCgpa        Float?
  minYear        Int?
  maxYear        Int?
  creditTransfer Boolean   @default(false)
  deadline       DateTime?
  feeAmount      Float?
  notes          String?
  sourceSystem   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([collegeId])
  @@map("transfer_requirements")
}

// ============================================================
// MODULE 4: COLLEGE REVIEWS
// ============================================================

model Review {
  id         String         @id @default(cuid())
  collegeId  String?
  college    College?       @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  authorId   String
  author     User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category   ReviewCategory
  rating     Int // 1-5
  title      String?
  body       String
  isVerified Boolean        @default(false) // only verified college students
  upvotes    Int            @default(0)
  downvotes  Int            @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  votes ReviewVote[]

  @@unique([collegeId, authorId, category])
  @@index([collegeId, category])
  @@index([upvotes(sort: Desc)])
  @@map("reviews")
}

model ReviewVote {
  id        String   @id @default(cuid())
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  value     Int // 1 or -1
  createdAt DateTime @default(now())

  @@unique([reviewId, userId])
  @@index([reviewId])
  @@map("review_votes")
}

// ============================================================
// MODULE 5: RESOURCE HUB
// ============================================================

model Resource {
  id          String       @id @default(cuid())
  uploaderId  String
  uploader    User         @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  type        ResourceType
  title       String
  description String?
  externalUrl String? // Google Drive / external link (preferred)
  fileKey     String? // S3 key (legacy file uploads)
  fileSize    Int?
  mimeType    String?
  tags        String[]
  collegeTag  String?
  courseTag   String?
  collegeId   String?
  college     College?     @relation(fields: [collegeId], references: [id])
  isFeatured  Boolean      @default(false)

  downloadCount Int   @default(0)
  avgRating     Float @default(0)
  ratingCount   Int   @default(0)
  likeCount     Int   @default(0)
  commentCount  Int   @default(0)
  shareCount    Int   @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  downloads ResourceDownload[]
  ratings   ResourceRating[]
  bookmarks ResourceBookmark[]
  likes     ResourceLike[]
  comments  ResourceComment[]

  @@index([type])
  @@index([tags])
  @@index([avgRating(sort: Desc)])
  @@index([collegeId])
  @@map("resources")
}

model ResourceLike {
  id         String   @id @default(cuid())
  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([resourceId, userId])
  @@index([userId])
  @@map("resource_likes")
}

model ResourceComment {
  id         String   @id @default(cuid())
  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body       String
  createdAt  DateTime @default(now())

  @@index([resourceId, createdAt])
  @@map("resource_comments")
}

model VerificationRequest {
  id                   String                    @id @default(cuid())
  userId               String
  user                 User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  collegeId            String?
  college              College?                  @relation(fields: [collegeId], references: [id])
  collegeName          String? // free-text college when not in the directory
  method               VerificationMethod
  collegeEmail         String?
  collegeEmailVerified Boolean                   @default(false) // student clicked the emailed link
  feedback             Json? // honest per-category thoughts about the college
  evidenceKey          String? // S3 key for ID card / admission proof
  status               VerificationRequestStatus @default(PENDING)
  note                 String?
  reviewedById         String?
  reviewedAt           DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([userId])
  @@map("verification_requests")
}

model CollegeFaq {
  id          String  @id @default(cuid())
  collegeId   String
  college     College @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  question    String
  answer      String
  order       Int     @default(0)
  createdById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([collegeId, order])
  @@map("college_faqs")
}

model ResourceDownload {
  id         String   @id @default(cuid())
  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([resourceId])
  @@index([userId])
  @@map("resource_downloads")
}

model ResourceRating {
  id         String   @id @default(cuid())
  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  value      Int // 1-5
  createdAt  DateTime @default(now())

  @@unique([resourceId, userId])
  @@index([resourceId])
  @@map("resource_ratings")
}

model ResourceBookmark {
  id         String   @id @default(cuid())
  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([resourceId, userId])
  @@index([userId])
  @@map("resource_bookmarks")
}

// ============================================================
// MODULE 6: MESSAGING
// ============================================================

model Chat {
  id            String    @id @default(cuid())
  type          ChatType
  title         String?
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())

  participants ChatParticipant[]
  messages     Message[]

  @@index([lastMessageAt(sort: Desc)])
  @@map("chats")
}

// Perk: career referral opportunities, open to every user.
model Referral {
  id          String   @id @default(cuid())
  role        String
  company     String
  description String?
  link        String?
  postedById  String
  postedBy    User     @relation(fields: [postedById], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@map("referrals")
}

// Lead/application captured by the 99x Developers startup landing page.
model AgencyLead {
  id         String   @id @default(cuid())
  kind       String // PROPOSAL | CAREER | INFLUENCER
  name       String
  email      String
  phone      String?
  services   String[] // selected services (PROPOSAL)
  message    String? // requirements / cover note
  role       String? // role applied for (CAREER)
  projectUrl String? // older project / portfolio (CAREER)
  videoUrls  String[] // 2 sample videos (INFLUENCER)
  status     String   @default("NEW") // NEW | CONTACTED | DONE
  createdAt  DateTime @default(now())

  @@index([kind, createdAt])
  @@map("agency_leads")
}

// Lead captured by the EZ-Rentbuddy startup landing (accommodation seeker or a
// property owner/broker sharing a listing for cashback).
model RentalLead {
  id           String   @id @default(cuid())
  kind         String // SEEKER | PROPERTY
  name         String
  phone        String?
  email        String?
  // seeker fields
  college      String?
  location     String?
  propertyType String? // PG | HOSTEL | FLAT | ROOM
  budget       String?
  moveInDate   String?
  occupants    String?
  gender       String?
  furnished    String?
  requirements String?
  // property-share fields
  participant  String? // OWNER | BROKER | STUDENT | RESIDENT
  driveUrl     String? // Google Drive folder with photos/videos/details
  details      String?
  status       String   @default("NEW")
  createdAt    DateTime @default(now())

  @@index([kind, createdAt])
  @@map("rental_leads")
}

// A student's request for 1:1 expert guidance ("Mentors" on the admin dashboard).
model MentorRequest {
  id               String   @id @default(cuid())
  name             String
  phone            String
  email            String?
  course           String? // course interest
  location         String? // preferred location
  marks            String? // marks / percentage
  budget           String?
  category         String? // optional
  preferredCollege String? // optional
  contactMethod    String? // CALL | CHAT
  message          String?
  status           String   @default("NEW") // NEW | CONTACTED | DONE
  createdAt        DateTime @default(now())

  @@index([createdAt])
  @@map("mentor_requests")
}

// One "EduBridge Profile" per student, filled across 4 steps. Each step's data is
// stored as JSON so the admin counselor card can swipe through them; completionPct
// advances 25 per finished step. Counselors add a private note and can delete the
// lead (with a reason logged to ProfileLeadDeletion) — which resets the student to
// a fresh form.
model ProfileLead {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String?
  phone         String?
  email         String?
  step1         Json? // welcome: name, dob, purpose, studying
  step2         Json? // contact: email, city, state, pin, phone
  step3         Json? // personalize: courses, cities, mode, degree, hostel, budget
  step4         Json? // academics: board, stream, marks, exams, doc names
  step5         Json? // next steps: quiz, comparePriorities, directApply
  completionPct Int      @default(0)
  adminNote     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([updatedAt])
  @@map("profile_leads")
}

// Audit trail for counselor-deleted profile leads — keeps the reason + a snapshot
// after the live lead is removed from every view.
model ProfileLeadDeletion {
  id        String   @id @default(cuid())
  userId    String
  name      String?
  reason    String
  snapshot  Json?
  deletedBy String
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("profile_lead_deletions")
}

// Per-email delivery audit — one row per send attempt (verification, reset, magic
// link, college-verify). Powers the admin "Email Management" view and deliverability
// debugging without leaking the email body.
model EmailLog {
  id        String   @id @default(cuid())
  to        String
  subject   String
  kind      String? // VERIFY | RESET | MAGIC_LINK | COLLEGE_VERIFY | OTHER
  status    String // SENT | FAILED | SKIPPED
  error     String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([status, createdAt])
  @@map("email_logs")
}

model ChatParticipant {
  id         String    @id @default(cuid())
  chatId     String
  chat       Chat      @relation(fields: [chatId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt DateTime?
  joinedAt   DateTime  @default(now())

  @@unique([chatId, userId])
  @@index([userId])
  @@map("chat_participants")
}

model Message {
  id          String        @id @default(cuid())
  chatId      String
  chat        Chat          @relation(fields: [chatId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User          @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body        String
  attachments String[]
  status      MessageStatus @default(SENT)
  createdAt   DateTime      @default(now())
  deletedAt   DateTime?

  @@index([chatId, createdAt(sort: Desc)])
  @@index([senderId])
  @@map("messages")
}

// ============================================================
// MODULE 7: REPUTATION & BADGES
// ============================================================

model ReputationEvent {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    ReputationAction
  points    Int
  refType   String? // post, comment, review...
  refId     String?
  createdAt DateTime         @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@map("reputation_events")
}

model Badge {
  id          String    @id @default(cuid())
  key         String    @unique // contributor, campus_expert...
  name        String
  description String?
  tier        BadgeTier @default(BRONZE)
  iconUrl     String?
  threshold   Int? // points or count needed

  userBadges UserBadge[]

  @@map("badges")
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId   String
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  awardedAt DateTime @default(now())

  @@unique([userId, badgeId])
  @@index([userId])
  @@map("user_badges")
}

// ============================================================
// MODULE 8: NOTIFICATIONS
// ============================================================

model Notification {
  id          String           @id @default(cuid())
  recipientId String
  recipient   User             @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actorId     String?
  actor       User?            @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  type        NotificationType
  title       String
  body        String?
  data        Json? // refType, refId, deeplink
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())

  @@index([recipientId, isRead, createdAt(sort: Desc)])
  @@map("notifications")
}

// ============================================================
// MODULE 9: INTERNSHIP PROGRAM
// ============================================================

model TrackAEnrollment {
  id                   String            @id @default(cuid())
  userId               String
  user                 User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  subtype              EnrollmentSubtype
  projectDescription   String
  feeAmount            Int // snapshot at enroll time; never re-read pricing config later
  status               EnrollmentStatus  @default(PENDING_PAYMENT)
  paymentReferenceNote String?
  paidAt               DateTime?
  paymentConfirmedById String?
  mentorNote           String?
  completedAt          DateTime?
  completedById        String?
  maintenanceUntil     DateTime? // OWN_PROJECT only: completedAt + 1 year
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  tasks EnrollmentTask[]

  @@index([userId, status])
  @@index([status, createdAt])
  @@map("track_a_enrollments")
}

model EnrollmentTask {
  id            String               @id @default(cuid())
  enrollmentId  String
  enrollment    TrackAEnrollment     @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  order         Int                  @default(0)
  status        EnrollmentTaskStatus @default(ASSIGNED)
  submissionUrl String?
  submittedAt   DateTime?
  reviewNote    String?
  reviewedById  String?
  reviewedAt    DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([enrollmentId, order])
  @@map("enrollment_tasks")
}

model TrackBApplication {
  id             String                  @id @default(cuid())
  userId         String
  user           User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills         String[]
  portfolioUrl   String?
  bio            String?
  status         TrackBApplicationStatus @default(PENDING)
  allocationType TrackBAllocationType?
  allocationNote String?
  allocatedById  String?
  allocatedAt    DateTime?
  submissionUrl  String?
  submittedAt    DateTime?
  reviewNote     String?
  reviewedById   String?
  reviewedAt     DateTime?
  payoutAmount   Float? // PAID_CLIENT_WORK only
  payoutSentAt   DateTime?
  payoutNote     String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@index([userId, status])
  @@index([status, createdAt])
  @@map("track_b_applications")
}

model Certificate {
  id            String                @id @default(cuid())
  code          String                @unique // e.g. EB-4F7K2QRT
  recipientId   String
  recipient     User                  @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  recipientName String // snapshot — survives later profile-name edits
  title         String // server-generated from subtype/allocationType, not admin-free-typed
  sourceType    CertificateSourceType
  sourceId      String // TrackAEnrollment.id or TrackBApplication.id
  issuedAt      DateTime              @default(now())
  metadata      Json? // subtype/allocationType/maintenanceUntil, for PDF rendering
  revokedAt     DateTime?

  @@unique([sourceType, sourceId]) // one certificate per enrollment/application
  @@index([recipientId])
  @@map("certificates")
}

// ============================================================
// ADMIN, MODERATION, AUDIT, RBAC
// ============================================================

model Report {
  id             String           @id @default(cuid())
  reporterId     String
  reporter       User             @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  targetType     ReportTargetType
  targetId       String
  reportedUserId String?
  reportedUser   User?            @relation("ReportedUser", fields: [reportedUserId], references: [id], onDelete: SetNull)
  reason         String
  details        String?
  status         ReportStatus     @default(OPEN)
  resolvedById   String?
  resolvedAt     DateTime?
  createdAt      DateTime         @default(now())

  @@index([status, createdAt])
  @@index([targetType, targetId])
  @@map("reports")
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action    String // user.ban, community.delete...
  entity    String?
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  permissions RolePermission[]
  createdAt   DateTime         @default(now())

  @@map("roles")
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique // user.ban, post.remove...
  description String?
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model Complaint {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  body         String
  status       String    @default("OPEN") // OPEN | RESOLVED
  resolvedById String?
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())

  @@index([status, createdAt])
  @@map("complaints")
}
