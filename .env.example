# ============================================================
# EduBridge Network — Environment Variables
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# ---- App ----
NODE_ENV=development
API_PORT=4000
WEB_PORT=3000
API_GLOBAL_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3000

# ---- Database (PostgreSQL) ----
DATABASE_URL="postgresql://edubridge:edubridge@localhost:5432/edubridge?schema=public"

# ---- Redis ----
REDIS_URL="redis://localhost:6379"

# ---- Elasticsearch ----
ELASTICSEARCH_NODE="http://localhost:9200"

# ---- JWT ----
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars-long"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars-long"
JWT_ACCESS_TTL=900            # 15 minutes (seconds)
JWT_REFRESH_TTL=2592000       # 30 days (seconds)

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:4000/api/v1/auth/google/callback"

# ---- Email (SMTP) ----
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="EduBridge Network <no-reply@edubridge.network>"

# ---- SMS / OTP (Twilio) ----
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
OTP_TTL=300                   # 5 minutes (seconds)

# ---- AWS S3 ----
AWS_REGION="ap-south-1"
AWS_S3_BUCKET="edubridge-uploads"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_SIGNED_URL_TTL=3600

# ---- Rate limiting ----
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=120

# ---- Frontend ----
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
NEXT_PUBLIC_WS_URL="http://localhost:4000"
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""

# ---- Observability ----
SENTRY_DSN=""
LOG_LEVEL=debug
