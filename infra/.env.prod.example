# ------------------------------------------------------------------
# Copy to infra/.env.prod and fill in real values. NEVER commit .env.prod.
# ------------------------------------------------------------------

# Your domain (no protocol, no www). The app is served at this + api.<domain>.
DOMAIN=yourdomain.com

# ---- Frontend build-time (baked into the browser bundle) ----
NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api/v1
NEXT_PUBLIC_WS_URL=https://api.yourdomain.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# ---- Backend ----
# Generate each with:  openssl rand -hex 48   (must be long, unique, and differ)
JWT_ACCESS_SECRET=REPLACE_WITH_A_LONG_RANDOM_STRING
JWT_REFRESH_SECRET=REPLACE_WITH_A_DIFFERENT_LONG_RANDOM_STRING
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
APP_URL=https://yourdomain.com
GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# ---- Database (hostname "postgres" is the compose service name) ----
POSTGRES_USER=edubridge
POSTGRES_PASSWORD=REPLACE_WITH_A_STRONG_DB_PASSWORD
POSTGRES_DB=edubridge
DATABASE_URL=postgresql://edubridge:REPLACE_WITH_A_STRONG_DB_PASSWORD@postgres:5432/edubridge?schema=public

# ---- Redis (hostname "redis" is the compose service name) ----
REDIS_URL=redis://redis:6379
